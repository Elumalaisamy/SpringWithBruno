meta {
  name: Get Product Not Found
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/api/products/999
  body: none
  auth: none
}

headers {
  Content-Type: application/json
}

tests {
  test("Status is 404", function() {
    expect(res.getStatus()).to.equal(404);
  });

  test("Response has success false", function() {
    expect(res.getBody().success).to.equal(false);
  });

  test("Error message is present", function() {
    expect(res.getBody().message).to.include("not found");
  });
}
