meta {
  name: Create Product Validation Error
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/products
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "",
    "price": -10,
    "quantity": -5
  }
}

tests {
  test("Status is 400 Bad Request", function() {
    expect(res.getStatus()).to.equal(400);
  });

  test("Response has success false", function() {
    expect(res.getBody().success).to.equal(false);
  });

  test("Validation errors are present", function() {
    expect(res.getBody().data).to.be.an("object");
  });
}
